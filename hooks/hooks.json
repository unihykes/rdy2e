{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-sessionStart.ps1",
        "type": "command",
        "timeout": 10,
        "failClosed": false
      }
    ],
    "sessionEnd": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-sessionEnd.ps1"
      }
    ],
    "preToolUse": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-preToolUse.ps1"
      }
    ],
    "postToolUse": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-postToolUse.ps1"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-postToolUseFailure.ps1"
      }
    ],
    "subagentStart": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-subagentStart.ps1"
      }
    ],
    "subagentStop": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-subagentStop.ps1",
        "loop_limit": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-beforeShellExecution.ps1"
      }
    ],
    "afterShellExecution": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-afterShellExecution.ps1"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-beforeMCPExecution.ps1"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-afterMCPExecution.ps1"
      }
    ],
    "beforeReadFile": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-beforeReadFile.ps1"
      }
    ],
    "afterFileEdit": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-afterFileEdit.ps1"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-beforeSubmitPrompt.ps1"
      }
    ],
    "preCompact": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-preCompact.ps1"
      }
    ],
    "stop": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-stop.ps1"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-afterAgentResponse.ps1"
      }
    ],
    "afterAgentThought": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\hooks\\r2e-hook-on-afterAgentThought.ps1"
      }
    ],
    "beforeTabFileRead": [],
    "afterTabFileEdit": []
  }
}